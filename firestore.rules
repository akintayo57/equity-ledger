rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global reads allowed for authenticated users.
    // Seeding is allowed for authenticated users (blocked on update/delete).
    match /securities/{securityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    // Pricing and FX rates are read-only for updates to prevent market manipulation.
    // Seeding is allowed for authenticated users (blocked on update/delete).
    match /prices/{priceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
    match /fxRates/{rateId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    match /exchanges/{exchangeId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    
    match /equityNotes/{noteId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    
    // User-specific collections are strictly locked to their owner.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /accounts/{accountId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /watchlist/{documentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
